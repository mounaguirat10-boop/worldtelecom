generator client {
  provider = "prisma-client-js"
}

datasource db {
   provider  = "postgresql",
  url       = env("DATABASE_URL"),
  directUrl = env("DIRECT_URL"),

model Revenue {
  id        String   @id @default(cuid())
  month     String
  amount    Float
  target    Float
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  address     String?
  serviceType String
  status      String   @default("نشط")
  joinDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id            String   @id @default(cuid())
  productName   String
  category      String
  quantity      Int
  minQuantity   Int      @default(10)
  unitPrice     Float
  supplier      String?
  barcode       String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NetworkIncident {
  id          String    @id @default(cuid())
  title       String
  area        String
  severity    String
  status      String    @default("مفتوح")
  reportedAt  DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NetworkMetric {
  id         String   @id @default(cuid())
  date       DateTime
  uptime     Float
  latency    Float
  throughput Float
  errors     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupportTicket {
  id           String   @id @default(cuid())
  customerName String
  subject      String
  description  String
  priority     String   @default("متوسط")
  status       String   @default("مفتوح")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  priority  String   @default("عادي")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Email {
  id        String   @id @default(cuid())
  from      String
  to        String
  subject   String
  body      String
  status    String   @default("مسودة")
  priority  String   @default("عادي")
  isRead    Boolean  @default(false)
  starred   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
